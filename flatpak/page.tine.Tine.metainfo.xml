<component type="desktop-application">
  <id>page.tine.Tine</id>

  <name>Tine</name>
  <summary>Fast Logseq-compatible outliner</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>AGPL-3.0-only</project_license>

  <developer id="page.tine">
    <name>Martin Koutecký</name>
  </developer>

  <description>
    <p>
      Tine is a fast, local-first outliner that reads and writes a real Logseq
      Markdown (and Org) graph on disk. It aims to feel like — and round-trip
      with — Logseq, so you can swap between the two on the same files.
    </p>
    <p>Features:</p>
    <ul>
      <li>An outliner with tasks, priorities and journals</li>
      <li>Page and block references, with backlinks</li>
      <li>Queries with a visual builder</li>
      <li>PDF and media viewing, with image and audio support</li>
      <li>HTML export of your graph</li>
      <li>Reads and writes the same Markdown/Org files as Logseq</li>
    </ul>
  </description>

  <launchable type="desktop-id">page.tine.Tine.desktop</launchable>

