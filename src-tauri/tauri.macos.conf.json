{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tine",
        "width": 1200,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": true,
        "titleBarStyle": "Overlay",
