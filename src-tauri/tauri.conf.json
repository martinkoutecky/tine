{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tine",
  "version": "0.1.0",
  "identifier": "dev.tine.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5181",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Tine",
        "width": 1200,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
