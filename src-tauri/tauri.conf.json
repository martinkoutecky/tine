{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tine",
  "version": "0.1.4",
  "identifier": "dev.tine.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5181",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Tine",
        "width": 1200,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480,
        "decorations": false
      },
      {
        "label": "capture",
        "url": "capture.html",
        "title": "Quick Capture",
        "width": 600,
        "height": 92,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "rpm", "nsis", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
