{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "logseq-claude",
  "version": "0.1.0",
  "identifier": "dev.logseqclaude.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5181",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "logseq-claude",
        "width": 1200,
        "height": 820,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.png"]
  }
}
